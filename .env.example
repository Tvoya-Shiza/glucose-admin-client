# Next.js dev port
PORT=4100

# In Phase 2 (BFF cookie auth wiring) we'll add:
# ADMIN_API_URL=http://localhost:4101
# JWT_ADMIN_SECRET=<must match glucose-admin-api/.env JWT_ADMIN_SECRET, used by jose.jwtVerify in middleware>

# ── Production / PM2 deploy ───────────────────────────────────────
# PM2 sets PORT=4100 from glucose-api/ecosystem.config.js. Don't override here.
#
# Required at deploy time (most land in Phase 2; documented forward):
#   ADMIN_API_URL=http://127.0.0.1:4101    # Internal — admin-client BFF talks server-to-server
#   JWT_ADMIN_SECRET=<MUST match glucose-admin-api JWT_ADMIN_SECRET>
#   NEXTAUTH_URL=https://<your-admin-host>/admin    # if Next basePath becomes '/admin'
