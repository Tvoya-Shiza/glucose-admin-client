# Copy this file to .env.local and fill in the real values for local development.
# .env.local is gitignored by default in Next.js projects, so secrets stay out of git.
#
# Next.js auto-loads .env.local for `next dev` and `next start`; you do NOT need
# any custom env-loading code.

# Next.js dev port (PM2 also sets PORT=4100 via glucose-api/ecosystem.config.js in prod).
PORT=4100

# Edge middleware verifies access tokens minted by admin-api with this secret.
# MUST match glucose-admin-api/.env JWT_ADMIN_SECRET exactly (admin-api signs, admin-client verifies).
# MinLength 32 — enforced server-side by admin-api; the middleware fails closed
# (rejects all tokens) if this is missing or shorter than 32 chars.
#
# IMPORTANT: NO NEXT_PUBLIC_ prefix — this secret must NEVER reach the browser.
# Next.js exposes process.env to Edge middleware at request time without that prefix.
JWT_ADMIN_SECRET=

# The admin-api origin used by BFF route handlers (Plan 06) for server-to-server forwarding.
# In dev:  http://localhost:4101
# In prod: https://admin-api.glucose.kz (or the deployed admin-api origin — internal/loopback preferred)
ADMIN_API_URL=http://localhost:4101

# Public site origin (used for redirect URLs, OG metadata, etc.).
# Optional — falls back to request origin if unset.
# Example: https://admin.glucose.kz
NEXT_PUBLIC_SITE_URL=

# Phase 5 Plan 04 — admin-api origin for the BFF-bypass file upload (CRS-05).
# The browser POSTs files DIRECTLY to admin-api authenticated by X-Upload-Token,
# NOT through /api/proxy/*. Leave EMPTY when admin-client and admin-api share an
# origin behind nginx in prod (same-origin → relative URL works).
#
# REQUIRED in dev when admin-client and admin-api run on different ports:
#   admin-client on 4100 / admin-api on 4101 → NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4101
# Without this, the browser will POST to http://localhost:4100/admin-api/... and 404.
# admin-api CORS_ORIGINS must include the admin-client origin for the upload to succeed.
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4101
